rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Role helpers ─────────────────────────────────────────────────────────
    function tokenRoles() {
      return request.auth != null && request.auth.token.roles != null;
    }
    function hasTokenRole(role) {
      return tokenRoles() && role in request.auth.token.roles;
    }
    // checks custom-claim first; falls back to users doc's roles array
    function hasRole(role) {
      return request.auth != null && (
        hasTokenRole(role) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         role in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles)
      );
    }
    // Convenience: any admin tier
    function isAdmin() {
      return hasRole('super_admin') || hasRole('corp_admin') || hasRole('system_admin');
    }
    // Any officer or admin who can manage reports
    function canManageReports() {
      return isAdmin() ||
        hasRole('corp_officer') || hasRole('ward_officer') ||
        hasRole('zonal_officer') || hasRole('sanitation_worker');
    }

    // Users — own profile or admin
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId || isAdmin();
      allow delete: if hasRole('super_admin') || hasRole('system_admin');
      
      match /notifications/{notificationId} {
        allow read, write: if request.auth.uid == userId || isAdmin();
      }
    }

    // Reports — any auth user creates; officers/admins update; super_admin can delete
    match /reports/{reportId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.reporterId == request.auth.uid;
      allow update: if request.auth != null && canManageReports();
      allow delete: if hasRole('super_admin') || hasRole('system_admin');
    }

    // Exchange listings (formerly waste_listings)
    match /exchange_listings/{listingId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.lister_uid == request.auth.uid
        && (hasRole('shop_owner') || hasRole('hotel_owner') || hasRole('market_vendor') || hasRole('citizen'));
      allow update: if request.auth != null && (
        resource.data.lister_uid == request.auth.uid || 
        resource.data.claimed_by_uid == request.auth.uid ||
        hasRole('farmer') || hasRole('animal_caretaker') || hasRole('recycler') || isAdmin()
      );
    }

    match /roleRequests/{uid} {
      allow read: if request.auth.uid == uid || isAdmin();
      allow create: if request.auth.uid == uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Wards — public read; any authenticated user can create (so they can add blocks); any admin can write/delete
    match /wards/{wardId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // Blocks — public read; any auth can write (citizen adoptions)
    match /blocks/{blockId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /cleanProofs/{proofId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.uploaderId == request.auth.uid;
    }

    match /badges/{badgeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cityStats/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /bins/{binId} {
      allow read: if true;
      allow create, update: if request.auth != null && canManageReports();
      allow delete: if isAdmin();
    }

    match /toilets/{toiletId} {
      allow read: if true;
      allow create, update: if request.auth != null && canManageReports();
      allow delete: if isAdmin();
    }

    match /toilet_ratings/{ratingId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.citizenId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /points_ledger/{ledgerId} {
      allow read: if request.auth != null && resource.data.user_uid == request.auth.uid || isAdmin();
      allow write: if false; // Only Cloud Functions can write
    }

    match /waste_credit_scores/{wardId} {
      allow read: if true;
      allow write: if false; // Only Cloud Functions
    }

    match /scrap_prices/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /dump_clusters/{clusterId} {
      allow read: if request.auth != null && canManageReports();
      allow write: if false; // Only Cloud Functions
    }

    match /specialZones/{zoneId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cleanupEvents/{eventId} {
      allow read: if request.auth != null;
      allow create, update: if isAdmin() || hasRole('college_admin');
      allow delete: if isAdmin();
    }

    match /settings/{document=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Worker pre-assignments for AI Predictions panel
    match /workerAssignments/{docId} {
      allow read: if request.auth != null && canManageReports();
      allow create: if request.auth != null && canManageReports();
      allow update, delete: if request.auth != null && (isAdmin() || hasRole('corp_officer') || hasRole('ward_officer') || hasRole('zonal_officer'));
    }

    match /mail/{document=**} {
      allow create: if request.auth != null;
    }

    // Forgot-password OTPs — only Cloud Functions (admin SDK) may read/write
    match /passwordResetOtps/{docId} {
      allow read, write: if false;
    }

    // Audit logs — admins read only; cloud functions write via admin SDK
    match /audit_log/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Cleanup/volunteer events — public read, officer/admin/college_admin can write
    match /events/{eventId} {
      allow read: if true;
      allow create: if request.auth != null && (canManageReports() || hasRole('college_admin'));
      allow update: if request.auth != null && (canManageReports() || hasRole('college_admin') || request.auth.uid in resource.data.attendees || resource.data.organizerId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Drain Watch — authenticated users inspect; officers see all
    match /drains/{drainId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if isAdmin();
    }

    // Ward broadcasts — authenticated read; officer/admin write
    match /broadcasts/{broadcastId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && canManageReports();
      allow update, delete: if isAdmin();
    }
  }
}

